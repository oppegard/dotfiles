#!/usr/bin/env bash

set -euo pipefail

run_repo_pre_commit() {
  local repo_hook

  repo_hook="$(git rev-parse --git-dir)/hooks/pre-commit"

  if [[ -x "$repo_hook" && "$repo_hook" != "$0" ]]; then
    "$repo_hook" "$@"
  fi
}

gitleaks_enabled="$(git config --bool --get hooks.gitleaks 2>/dev/null || true)"

if [[ "$gitleaks_enabled" != "false" ]]; then
  if command -v gitleaks >/dev/null 2>&1; then
    if ! gitleaks git --pre-commit --redact --staged --verbose --log-level warn --no-banner; then
      printf '[pre-commit] aborting commit: \033[31mdetected potential secrets\033[0m.\n' >&2
      exit 1
    fi
  else
    printf '[pre-commit] \033[31mskipping secret scan:\033[0m https://github.com/gitleaks/gitleaks not found.\n' >&2
  fi
else
  printf '[pre-commit] \033[31mskipping secret scan:\033[0m gitleaks disabled.\n' >&2
fi

run_repo_pre_commit "$@"
