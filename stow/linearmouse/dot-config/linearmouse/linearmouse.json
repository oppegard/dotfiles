        "smoothed" : {
          "vertical" : {
            "acceleration" : 0.86,
            "bouncing" : true,
            "enabled" : true,
            "inertia" : 0.74,
            "preset" : "easeInOut",
            "response" : 0.68,
            "speed" : 1.02
          }
        },
        "speed" : {
          "vertical" : 0
        }
      }
    },
    {
      "if" : {
        "app" : "com.bambulab.bambu-studio",
        "device" : {
          "category" : "mouse",
          "productID" : "0x82a",
          "productName" : "Microsoft Pro Intellimouse",
          "vendorID" : "0x45e"
        }
      },
      "scrolling" : {
        "acceleration" : 0.35,
        "distance" : "auto",
        "modifiers" : {
          "shift" : {
            "type" : "alterOrientation"
          }
        },
        "smoothed" : {
          "enabled" : false
        },
        "speed" : 0.4
      }
    }
  ]
}