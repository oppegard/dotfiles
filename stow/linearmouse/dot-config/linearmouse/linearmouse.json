{
  "$schema" : "https:\/\/schema.linearmouse.app\/0.11.2",
  "schemes" : [
    {
      "buttons" : {
        "universalBackForward" : true
      },
      "if" : {
        "device" : {
          "category" : "mouse",
          "productID" : "0x82a",
          "productName" : "Microsoft Pro Intellimouse",
          "vendorID" : "0x45e"
        }
      },
      "pointer" : {
        "acceleration" : "unset",
        "disableAcceleration" : false,
        "redirectsToScroll" : false,
        "speed" : "unset"
      },
      "scrolling" : {
