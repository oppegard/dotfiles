#!/bin/bash
#Generated by JetBrains Toolbox 3.6.2.85969 at 2026-07-16T07:37:54

declare -a intellij_args=()
declare -- wait=""

for o in "$@"; do
  if [[ "$o" = "--wait" || "$o" = "-w" ]]; then
    wait="-W"
    o="--wait"
  fi
  if [[ "$o" =~ " " ]]; then
    intellij_args+=("\"$o\"")
  else
    intellij_args+=("$o")
  fi
done

open -na "/Users/glenn/Applications/IntelliJ IDEA.app/Contents/MacOS/idea" $wait --args "${intellij_args[@]}"